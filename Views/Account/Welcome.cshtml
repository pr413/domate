@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); height: 100vh; display: flex; align-items: center; justify-content: center; color: white; }
        .welcome-card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border-radius: 20px; padding: 40px; border: 1px solid rgba(255,255,255,0.2); }
    </style>
</head>
<body>
    <div class="welcome-card text-center shadow-lg">
        <h1>Welcome to DoMate 🚀</h1>
        <p>Your ultimate task manager</p>
        
        <div class="mt-4">
            <label class="d-block mb-2">Select Language / भाषा निवडा</label>
            <select class="form-select w-75 mx-auto mb-3" id="lang">
                <option value="en">English</option>
                <option value="hi">Hindi (हिंदी)</option>
                <option value="mr">Marathi (मराठी)</option>
            </select>
        </div>

        <button class="btn btn-warning mb-4" onclick="askNotify()">Enable Notifications 🔔</button>
        <br>
        <a href="/Account/Login" class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-primary">Get Started</a>
    </div>

    <script>
        function askNotify() {
            Notification.requestPermission().then(p => {
                if(p === 'granted') alert('Notifications Enabled!');
                else alert('Notification blocked.');
            });
        }
    </script>
</body>
</html>